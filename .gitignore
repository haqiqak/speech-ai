# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── NLTK data (downloaded at runtime, not committed) ─────────────────────────
nltk_data/

# ── SBERT / sentence-transformers + all runtime model/data caches ─────────────
# The SBERT model, torch hub, and NLTK data are downloaded to .cache/ on first
# run.  Do NOT commit — too large and regenerates automatically.
.cache/

# ── User preferences written at runtime ───────────────────────────────────────
user_prefs.json

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Jupyter / IPython ─────────────────────────────────────────────────────────
